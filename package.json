{
  "name": "eon-funtime-helper",
  "private": true,
  "version": "0.1.0",
  "description": "Production-ready Telegram bot + admin panel for FunTime events",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "dev:stable": "pnpm --filter @eon/core-api dev",
    "dev:web": "pnpm --filter @eon/admin-web dev",
    "dev:bot": "pnpm --filter @eon/bot-service dev",
    "start:core-api": "pnpm --filter @eon/core-api start",
    "start:web": "pnpm --filter @eon/admin-web start",
    "start:bot": "pnpm --filter @eon/bot-service start",
    "start:scheduler": "pnpm --filter @eon/scheduler-worker start",
    "start:billing": "pnpm --filter @eon/billing-worker start",
    "start:stack": "node ./scripts/start-stack.js",
    "logs:stack": "node -e \"const fs=require('node:fs');const p='logs/runtime';if(!fs.existsSync(p)){console.log('no logs yet');process.exit(0)};for(const f of fs.readdirSync(p)){console.log('--- '+f+' ---');console.log(fs.readFileSync(require('node:path').join(p,f),'utf8').split('\\n').slice(-40).join('\\n'));}\"",
    "db:generate": "pnpm --filter @eon/core-api prisma:generate",
    "db:migrate:deploy": "pnpm --filter @eon/core-api prisma:migrate:deploy",
    "build:bot": "pnpm --filter @eon/shared-domain build && pnpm --filter @eon/bot-service build",
    "dev:bot:clean": "powershell -ExecutionPolicy Bypass -File ./scripts/start-bot-clean.ps1",
    "dev:workers": "pnpm --filter @eon/scheduler-worker dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "prisma": "5.22.0",
    "tsx": "^4.21.0",
    "typescript": "5.5.4"
  },
  "dependencies": {
    "zod": "^3.23.8"
  }
}
