{
  "name": "@eon/core-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx -r dotenv/config src/main.ts dotenv_config_path=../../.env",
    "start": "node -r dotenv/config dist/main.js dotenv_config_path=../../.env",
    "start:prod": "node dist/main.js",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"No lint configured\"",
    "test": "echo \"No tests yet\""
  },
  "dependencies": {
    "@eon/shared-config": "workspace:*",
    "@eon/shared-domain": "workspace:*",
    "@eon/shared-infra": "workspace:*",
    "@nestjs/common": "^10.4.2",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.2",
    "@nestjs/platform-express": "^10.4.2",
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.7",
    "bullmq": "^5.21.2",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "winston": "^3.15.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
