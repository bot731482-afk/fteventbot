[Unit]
Description=fteventbot admin-web
After=network.target core-api.service
Wants=core-api.service

[Service]
Type=simple
WorkingDirectory=/opt/fteventbot
EnvironmentFile=/opt/fteventbot/.env
Environment=NODE_ENV=production
Environment=PORT=3100
Environment=NEXT_PUBLIC_ADMIN_PROXY_MODE=true
Environment=CORE_API_INTERNAL_URL=http://127.0.0.1:3000/v1
ExecStart=/usr/bin/pnpm --filter @eon/admin-web start
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
