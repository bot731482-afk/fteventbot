NODE_ENV=development
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DIRECT_DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
REDIS_URL=redis://localhost:6379

FUNTIME_API_BASE_URL=https://api.funtime.su
FUNTIME_API_TOKEN=your_funtime_api_token

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_REQUIRED_CHANNELS=
OWNER_ADMIN_ID=0

CRYPTOBOT_BASE_URL=https://pay.crypt.bot/api
CRYPTOBOT_API_TOKEN=your_cryptobot_token

CORE_API_URL=http://localhost:3000/v1
CORE_API_HOST=127.0.0.1
CORE_API_PORT=3000
NEXT_PUBLIC_CORE_API_URL=http://localhost:3000/v1
NEXT_PUBLIC_ADMIN_PROXY_MODE=true
CORE_API_INTERNAL_URL=http://127.0.0.1:3000/v1
ADMIN_WEB_URL=http://127.0.0.1:3100
CORE_API_HEALTH_URL=http://127.0.0.1:3000/v1/bot/config
ADMIN_WEB_HEALTH_URL=http://127.0.0.1:3100
STACK_STARTUP_TIMEOUT_MS=120000

# Bot ↔ core-api (must match; required when CORE_API_URL is set)
BOT_SERVICE_SECRET=change_me_min_8_chars

# Bot behavior
BOT_COOLDOWN_SECONDS=10
BOT_ENABLED=true
BOT_LAUNCH_RETRY_MS=30000
BOT_LAUNCH_TIMEOUT_MS=15000
TELEGRAM_PROXY_URL=
BOT_CONFIG_PATH=
BOT_CONFIG_CACHE_PATH=
BOT_POLLING_OFFSET_PATH=
BOT_CONFIG_STORE_PATH=
BOT_CONFIG_HISTORY_DIR=

# Billing switch (later: set to "cryptobot" and run billing-worker)
PAYMENTS_MODE=free
